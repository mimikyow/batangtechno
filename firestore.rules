rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * BATANG TECHNO SECURITY RULES
     * 
     * Implements DBAC (Database-Based Access Control) for Admins and Judges.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isJudge() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_judge/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the authenticated judge is assigned to a specific entry.
     */
    function isAssignedToEntry(entryId) {
      return get(/databases/$(database)/documents/entries/$(entryId)).data.assignedJudges[request.auth.uid] == true;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      // Allow create for the hardcoded admin email logic in the prototype
      allow create: if isOwner(adminId);
      allow list, update, delete: if isAdmin();
    }

    match /roles_judge/{judgeId} {
      allow get: if isOwner(judgeId) || isAdmin();
      // Allow create for the hardcoded judge email logic in the prototype
      allow create: if isOwner(judgeId);
      allow list: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /challenges/{challengeId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /criteria/{criterionId} {
      allow get, list: if isAdmin() || isJudge();
      allow create, update, delete: if isAdmin();
    }

    match /entries/{entryId} {
      // Public can see approved entries. Admins and assigned judges can see any.
      allow get, list: if (resource != null && resource.data.adminApproved == true) || isAdmin() || (isJudge() && resource.data.assignedJudges[request.auth.uid] == true);
      allow create, update, delete: if isAdmin();

      match /scoreSubmissions/{scoreSubmissionId} {
        allow get, list: if isAdmin() || (isJudge() && resource.data.judgeId == request.auth.uid);
        allow create: if isJudge() && isAssignedToEntry(entryId) && request.resource.data.judgeId == request.auth.uid;
        allow update: if isAdmin() || (isJudge() && resource.data.judgeId == request.auth.uid);
        allow delete: if isAdmin();
      }
    }

    match /judgeAssignments/{assignmentId} {
      allow get, list, create, update, delete: if isAdmin();
    }
  }
}