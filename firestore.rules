
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isJudge() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_judge/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow create: if isOwner(adminId) || isAdmin();
      allow list, update, delete: if isAdmin();
    }

    match /roles_judge/{judgeId} {
      allow get: if isOwner(judgeId) || isAdmin();
      allow create: if isOwner(judgeId) || isAdmin();
      allow list: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /challenges/{challengeId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /entries/{entryId} {
      allow list, get: if true;
      allow create, update, delete: if isAdmin();

      match /scoreSubmissions/{scoreSubmissionId} {
        allow get, list: if isAdmin() || (isJudge() && request.auth.uid == scoreSubmissionId);
        allow create, update: if isJudge() && request.auth.uid == scoreSubmissionId;
        allow delete: if isAdmin();
      }
    }

    // Collection group rule for judges to see their own history
    match /{path=**}/scoreSubmissions/{scoreSubmissionId} {
      allow list: if isJudge() && (isAdmin() || request.auth.uid == scoreSubmissionId);
    }

    match /judgeAssignments/{assignmentId} {
      allow get, list, create, update, delete: if isAdmin();
    }
  }
}
